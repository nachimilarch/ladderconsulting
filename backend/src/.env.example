# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:5173

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ── SSO Login ────────────────────────────────────────
# Set SSO_ENFORCED=true only after Microsoft + Google are fully configured.
# When false (default), all roles can use the email+password form at /login/trainer.
SSO_ENFORCED=false
MICROSOFT_CLIENT_ID=your_azure_ad_application_client_id
# Tenant ID from App Registration Overview page ("Directory (tenant) ID")
MICROSOFT_TENANT_ID=your_azure_ad_directory_tenant_id
# Client secret from App Registration → Certificates & secrets → New client secret
# Also needs Mail.Read + Mail.Send application permissions with admin consent granted
MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret_value
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ── AWS S3 ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=ladder-consulting-files

# ── Email (Microsoft 365 SMTP) ───────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=crm@theladderconsulting.com
SMTP_PASS=
EMAIL_FROM="LadderStep Human Consulting <crm@theladderconsulting.com>"

# ── Outreach SMTP (Microsoft 365 — same account) ─────
GODADDY_SMTP_HOST=smtp.office365.com
GODADDY_SMTP_PORT=587
GODADDY_SMTP_SECURE=false
GODADDY_SMTP_USER=crm@theladderconsulting.com
GODADDY_SMTP_PASS=
GODADDY_DEFAULT_FROM_NAME=LadderStep Human Consulting

# ── Outreach IMAP (Microsoft 365 — reply polling) ────
GODADDY_IMAP_HOST=outlook.office365.com
GODADDY_IMAP_PORT=993
GODADDY_IMAP_SECURE=true
GODADDY_IMAP_USER=crm@theladderconsulting.com
GODADDY_IMAP_PASS=

# ── AI / LLM ─────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key
AI_MATCH_MODEL=gpt-4o-mini
AI_MATCH_THRESHOLD=40

# ── WhatsApp (Phase 2) ───────────────────────────────
# WHATSAPP_API_URL=
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=