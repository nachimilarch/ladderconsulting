# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:5173

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ── SSO Login ────────────────────────────────────────
# Microsoft 365 (hr_staff, admin) — Azure AD app registration, "Accounts in
# any organizational directory and personal Microsoft accounts", SPA platform.
# Client secret is NOT needed — the backend only verifies ID tokens.
MICROSOFT_CLIENT_ID=your_azure_ad_application_client_id
# Google (candidate, company) — Google Cloud Console OAuth client ID (Web application).
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ── AWS S3 ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=ladder-consulting-files

# ── Email (Nodemailer) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="LadderStep Human Consulting <noreply@ladderconsulting.in>"

# ── AI / LLM ─────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key
AI_MATCH_MODEL=gpt-4o-mini
AI_MATCH_THRESHOLD=40

# ── WhatsApp (Phase 2) ───────────────────────────────
# WHATSAPP_API_URL=
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=