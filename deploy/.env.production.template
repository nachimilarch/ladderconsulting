# Production backend/.env — copy to backend/.env on the EC2 instance and fill
# in the placeholders. JWT secrets below are freshly generated and safe to use
# as-is (don't reuse them anywhere else though).

# ── App ──────────────────────────────────────────────
NODE_ENV=production
PORT=5001
# Comma-separated if you ever need more than one (e.g. apex + www).
# HTTP/IP for now since there's no domain yet — update this the moment you add one.
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP

# ── Database (self-hosted MySQL on this same instance) ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ladder_consulting
DB_USER=root
DB_PASSWORD=CHANGE_ME_STRONG_MYSQL_PASSWORD

# ── JWT — freshly generated, safe to use as-is ───────
JWT_SECRET=25f5be18744bfbb6c4740d3afcc55a4690266e6f572b42ba69f36dde71b21f2f9163d71230b21594bf1f22c36a52abb3
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=53cc80a16aa57274939b2725f1ade2ab8b541b00cf4e5a835ac943c391fe18d382fa91ee327ff477a1835a6f578982cc
JWT_REFRESH_EXPIRES_IN=30d

# ── SSO Login ────────────────────────────────────────
# SSO_ENFORCED=false lets all roles use the email+password form at /login/trainer
# (safe during initial setup). Flip to true once Microsoft + Google are live.
SSO_ENFORCED=false
MICROSOFT_CLIENT_ID=your_azure_ad_application_client_id
MICROSOFT_TENANT_ID=your_azure_ad_directory_tenant_id
MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret_value
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ── AWS S3 (resume/document storage) ─────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# ── Transactional Email (Microsoft 365 SMTP) ─────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=crm@theladderconsulting.com
SMTP_PASS=
EMAIL_FROM="LadderStep Human Consulting <crm@theladderconsulting.com>"

# ── Outreach SMTP/IMAP (Microsoft 365) ───────────────
GODADDY_SMTP_HOST=smtp.office365.com
GODADDY_SMTP_PORT=587
GODADDY_SMTP_SECURE=false
GODADDY_SMTP_USER=crm@theladderconsulting.com
GODADDY_SMTP_PASS=
GODADDY_DEFAULT_FROM_NAME=LadderStep Human Consulting
GODADDY_IMAP_HOST=outlook.office365.com
GODADDY_IMAP_PORT=993
GODADDY_IMAP_SECURE=true
GODADDY_IMAP_USER=crm@theladderconsulting.com
GODADDY_IMAP_PASS=

# ── Cashfree Payments — REAL/PROD credentials, not TEST ──
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=PROD
CASHFREE_BASE_URL_PROD=https://api.cashfree.com/pg
CASHFREE_WEBHOOK_SECRET=

# ── WhatsApp Cloud API (optional — leave blank if not using yet) ──
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ── AI matching (offline parser — this key is optional, only used for
# training-course recommendations; leave unset if not using that feature) ──
# OPENAI_API_KEY=
AI_MATCH_THRESHOLD=40
